# Hearth Mobile — Environment Variables (Expo)
# Prefix with EXPO_PUBLIC_ to expose to client
# Copy to .env.local

# API
EXPO_PUBLIC_API_URL="http://localhost:4000"

# Clerk (get from https://dashboard.clerk.com)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Cloudinary unsigned upload preset (for direct photo uploads from mobile)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET="hearth_meals"

# Mapbox (for pickup location maps)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN="pk...."
