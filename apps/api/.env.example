# Hearth API — Environment Variables
# Copy to .env and fill in values

# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hearth"

# ─── Auth (Clerk) ────────────────────────────────────────
# Get from https://dashboard.clerk.com
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."  # For syncing users to our DB

# ─── Stripe ──────────────────────────────────────────────
# Get from https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_..."    # Round Member $7.99/mo
STRIPE_PRICE_ANNUAL="price_..."     # Round Member $59/yr
STRIPE_PRICE_FOUNDING="price_..."   # Founding Member $49 (launch only — retire after launch, move to $89)

# ─── Cloudinary (meal photo uploads) ─────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."
CLOUDINARY_UPLOAD_PRESET="hearth_meals"  # unsigned preset

# ─── SendGrid (email notifications) ──────────────────────
SENDGRID_API_KEY="SG...."
EMAIL_FROM="noreply@round.app"

# ─── App ─────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
HOST="0.0.0.0"
WEB_URL="http://localhost:3000"

# ─── Cron (cook day reminders, etc.) ─────────────────────
# Used to authenticate internal cron endpoints
CRON_SECRET="a-random-secret-for-cron-auth"
CRON_SECRET="a-long-random-secret-change-this"     # shared with your scheduler
