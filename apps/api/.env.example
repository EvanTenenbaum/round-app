# Database
DATABASE_URL="postgresql://round:round_local@localhost:5432/round_dev"

# Clerk Auth
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
JWKS_URL="https://clerk.your-domain.com/.well-known/jwks.json"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_..."       # $7.99/mo Round Member
STRIPE_PRICE_ANNUAL="price_..."        # $59/yr Round Member
STRIPE_PRICE_FOUNDING="price_..."      # $49 one-time Founding Member

# Cloudinary (meal photo uploads)
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Cron jobs (shared secret with scheduler)
CRON_SECRET="change-this-to-a-long-random-string"

# Server
PORT=4000
HOST="0.0.0.0"
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000"    # comma-separated for multiple
